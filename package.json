{
  "name": "aia-deck",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "slidev build",
    "dev": "slidev --open",
    "export:pdf": "slidev export --format pdf --wait 1500 --wait-until load --timeout 90000",
    "export:pptx": "slidev export --format pptx --wait 1500 --wait-until load --timeout 90000"
  },
  "dependencies": {
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.1",
    "playwright-chromium": "^1.61.1"
  }
}