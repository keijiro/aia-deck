{
  "name": "aia-deck",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "slidev build --base /aia-deck/",
    "build:kr": "slidev build slides-kr.md --base /aia-deck/",
    "dev": "slidev --open",
    "dev:kr": "slidev slides-kr.md --open",
    "export": "slidev export --format pptx --wait 1500 --wait-until load --timeout 90000",
    "export:kr": "slidev export slides-kr.md --format pptx --wait 1500 --wait-until load --timeout 90000"
  },
  "dependencies": {
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.1",
    "playwright-chromium": "^1.61.1"
  }
}